{
  "$schema": "https://tokens.studio/schema.json",
  "$description": "Design tokens extraídos do código do site Ale Vencato Reiki. Formato Tokens Studio / W3C Design Tokens — importável no Figma via plugin Tokens Studio ou consumível por MCP.",
  "color": {
    "brand": {
      "gold": {
        "$type": "color",
        "$value": "#B8956A",
        "$description": "Cor primária — botões, acentos, links e decoradores."
      },
      "gold-light": {
        "$type": "color",
        "$value": "#D4AF82",
        "$description": "Hover de botões dourados e linha decoradora."
      },
      "gold-pale": {
        "$type": "color",
        "$value": "#F0E6D6",
        "$description": "Tom bege claro usado em blobs e fundos sutis."
      },
      "gold-deep": {
        "$type": "color",
        "$value": "#4A2E0A",
        "$description": "Marrom escuro usado em texto de badges e CTAs secundários."
      }
    },
    "accent": {
      "lilac": {
        "$type": "color",
        "$value": "#D7CBD9",
        "$description": "Lilás suave — acentos e blobs decorativos."
      },
      "lilac-mid": {
        "$type": "color",
        "$value": "#C4B5C8",
        "$description": "Lilás médio — detalhes e separadores."
      },
      "lilac-pale": {
        "$type": "color",
        "$value": "#F0EBF2",
        "$description": "Lilás muito claro — fundos de seção."
      }
    },
    "surface": {
      "off-white": {
        "$type": "color",
        "$value": "#FAFAF8",
        "$description": "Fundo padrão do site (body) e cor de texto sobre botão dourado."
      },
      "cream": {
        "$type": "color",
        "$value": "#F5F0EB",
        "$description": "Fundo da hero section e cards flutuantes."
      }
    },
    "text": {
      "primary": {
        "$type": "color",
        "$value": "#4A4040",
        "$description": "Texto principal — headings e conteúdo de destaque."
      },
      "secondary": {
        "$type": "color",
        "$value": "#7A6E6E",
        "$description": "Texto de apoio — parágrafos, labels secundárias."
      },
      "body-soft": {
        "$type": "color",
        "$value": "#524848",
        "$description": "Variação de texto de corpo usada na hero — leve warm shift."
      }
    },
    "alpha": {
      "gold-10": {
        "$type": "color",
        "$value": "rgba(184, 149, 106, 0.10)",
        "$description": "Fundo sutil para badges."
      },
      "gold-12": {
        "$type": "color",
        "$value": "rgba(184, 149, 106, 0.12)",
        "$description": "Sombra de hover em cards."
      },
      "gold-15": {
        "$type": "color",
        "$value": "rgba(184, 149, 106, 0.15)",
        "$description": "Borda fina em float cards."
      },
      "gold-20": {
        "$type": "color",
        "$value": "rgba(184, 149, 106, 0.20)",
        "$description": "Fundo de badge em seções escuras; borda em frames de imagem."
      },
      "gold-22": {
        "$type": "color",
        "$value": "rgba(184, 149, 106, 0.22)",
        "$description": "Borda de social icons no footer."
      },
      "gold-25": {
        "$type": "color",
        "$value": "rgba(184, 149, 106, 0.25)",
        "$description": "Borda de badges da hero."
      },
      "gold-30": {
        "$type": "color",
        "$value": "rgba(184, 149, 106, 0.30)",
        "$description": "Borda de chips e tags (SobreAle)."
      },
      "gold-35": {
        "$type": "color",
        "$value": "rgba(184, 149, 106, 0.35)",
        "$description": "Sombra de botão pequeno."
      },
      "gold-40": {
        "$type": "color",
        "$value": "rgba(184, 149, 106, 0.40)",
        "$description": "Sombra de botão do header."
      },
      "gold-45": {
        "$type": "color",
        "$value": "rgba(184, 149, 106, 0.45)",
        "$description": "Sombra de botão primário padrão."
      },
      "gold-50": {
        "$type": "color",
        "$value": "rgba(184, 149, 106, 0.50)",
        "$description": "Sombra de botão primário em hover."
      },
      "lilac-45": {
        "$type": "color",
        "$value": "rgba(215, 203, 217, 0.45)",
        "$description": "Centro do blob decorativo da hero."
      },
      "gold-pale-20": {
        "$type": "color",
        "$value": "rgba(240, 230, 214, 0.20)",
        "$description": "Meio do blob decorativo da hero."
      },
      "white-15": {
        "$type": "color",
        "$value": "rgba(255, 255, 255, 0.15)",
        "$description": "Overlay radial do CTA final."
      }
    }
  },
  "typography": {
    "font-family": {
      "serif": {
        "$type": "fontFamily",
        "$value": "Cormorant Garamond",
        "$description": "Fonte serifada — usada em headings principais, logo, quotes e itálicos."
      },
      "sans": {
        "$type": "fontFamily",
        "$value": "Jost",
        "$description": "Fonte sans-serif — corpo de texto, labels, eyebrows e botões."
      }
    },
    "font-weight": {
      "extralight": { "$type": "fontWeight", "$value": 200 },
      "light":      { "$type": "fontWeight", "$value": 300 },
      "regular":    { "$type": "fontWeight", "$value": 400 },
      "medium":     { "$type": "fontWeight", "$value": 500 }
    },
    "style": {
      "h1-hero": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{typography.font-family.serif}",
          "fontWeight": 300,
          "fontSize": "4.6rem",
          "lineHeight": 1.1,
          "letterSpacing": "0.3px"
        },
        "$description": "Headline da hero — clamp(2.2rem, 4.8vw, 4.6rem) no código."
      },
      "h2-section": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{typography.font-family.serif}",
          "fontWeight": 300,
          "fontSize": "3rem",
          "lineHeight": 1.2
        },
        "$description": "Título de seção — clamp(2rem, 3.2vw, 3rem) no código."
      },
      "h3-card": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{typography.font-family.serif}",
          "fontWeight": 400,
          "fontSize": "1.7rem",
          "lineHeight": 1.3
        },
        "$description": "Título de card (Sessoes)."
      },
      "quote-italic": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{typography.font-family.serif}",
          "fontWeight": 300,
          "fontSize": "1.15rem",
          "fontStyle": "italic",
          "lineHeight": 1.85
        },
        "$description": "Quotes e frases em itálico (Testimonials, Hero, FAQ)."
      },
      "body-lg": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{typography.font-family.sans}",
          "fontWeight": 300,
          "fontSize": "1rem",
          "lineHeight": 1.9
        },
        "$description": "Parágrafo padrão das seções."
      },
      "body-md": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{typography.font-family.sans}",
          "fontWeight": 300,
          "fontSize": "0.95rem",
          "lineHeight": 1.85
        },
        "$description": "Parágrafo compacto em cards."
      },
      "eyebrow-lg": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{typography.font-family.sans}",
          "fontWeight": 300,
          "fontSize": "0.65rem",
          "letterSpacing": "5px",
          "textCase": "uppercase"
        },
        "$description": "Eyebrow acima de todos os H2 (cor gold)."
      },
      "eyebrow-md": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{typography.font-family.sans}",
          "fontWeight": 300,
          "fontSize": "0.7rem",
          "letterSpacing": "3px",
          "textCase": "uppercase"
        },
        "$description": "Eyebrow médio — breadcrumbs de seção, badges."
      },
      "eyebrow-sm": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{typography.font-family.sans}",
          "fontWeight": 300,
          "fontSize": "0.62rem",
          "letterSpacing": "2px",
          "textCase": "uppercase"
        },
        "$description": "Labels micro — footer, float cards."
      },
      "button": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{typography.font-family.sans}",
          "fontWeight": 400,
          "fontSize": "0.8rem",
          "letterSpacing": "2px",
          "textCase": "uppercase"
        },
        "$description": "Texto do CTA primário."
      },
      "button-sm": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{typography.font-family.sans}",
          "fontWeight": 400,
          "fontSize": "0.75rem",
          "letterSpacing": "1.5px",
          "textCase": "uppercase"
        },
        "$description": "Botão compacto (header, cards)."
      },
      "nav-link": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{typography.font-family.sans}",
          "fontWeight": 300,
          "fontSize": "0.75rem",
          "letterSpacing": "2px",
          "textCase": "uppercase"
        },
        "$description": "Links do menu do header."
      },
      "logo": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{typography.font-family.serif}",
          "fontWeight": 300,
          "fontSize": "1.05rem",
          "letterSpacing": "4px",
          "textCase": "uppercase"
        },
        "$description": "Logo textual no header."
      }
    }
  },
  "spacing": {
    "section-x": {
      "$type": "dimension",
      "$value": "6%",
      "$description": "Padding horizontal padrão das seções."
    },
    "container-max": {
      "$type": "dimension",
      "$value": "1100px",
      "$description": "Largura máxima do grid principal."
    },
    "button-px": {
      "$type": "dimension",
      "$value": "44px",
      "$description": "Padding horizontal do CTA primário (px-11)."
    },
    "button-py": {
      "$type": "dimension",
      "$value": "20px",
      "$description": "Padding vertical do CTA primário (py-5)."
    }
  },
  "border-radius": {
    "none": { "$type": "dimension", "$value": "0px", "$description": "Default — cards, botões e frames têm cantos retos (estética minimalista)." },
    "full": { "$type": "dimension", "$value": "9999px", "$description": "Blob decorativo e indicador pulsante." }
  },
  "shadow": {
    "button-sm": {
      "$type": "shadow",
      "$value": { "color": "rgba(184,149,106,0.35)", "offsetX": "0px", "offsetY": "4px", "blur": "16px", "spread": "0px" },
      "$description": "Sombra de botão em card (Sessoes)."
    },
    "button-md": {
      "$type": "shadow",
      "$value": { "color": "rgba(184,149,106,0.40)", "offsetX": "0px", "offsetY": "4px", "blur": "14px", "spread": "0px" },
      "$description": "Sombra de botão do header."
    },
    "button-lg": {
      "$type": "shadow",
      "$value": { "color": "rgba(184,149,106,0.45)", "offsetX": "0px", "offsetY": "6px", "blur": "24px", "spread": "0px" },
      "$description": "Sombra padrão do CTA primário."
    },
    "button-hover": {
      "$type": "shadow",
      "$value": { "color": "rgba(184,149,106,0.50)", "offsetX": "0px", "offsetY": "10px", "blur": "32px", "spread": "0px" },
      "$description": "Sombra do CTA primário em :hover."
    },
    "card-hover": {
      "$type": "shadow",
      "$value": { "color": "rgba(184,149,106,0.12)", "offsetX": "0px", "offsetY": "20px", "blur": "48px", "spread": "0px" },
      "$description": "Elevação em :hover dos cards."
    }
  },
  "motion": {
    "duration": {
      "fast":   { "$type": "duration", "$value": "300ms" },
      "medium": { "$type": "duration", "$value": "2s",  "$description": "Pulse gold loop." }
    },
    "easing": {
      "default": { "$type": "cubicBezier", "$value": [0.4, 0, 0.2, 1] }
    }
  },
  "decorators": {
    "gold-line": {
      "$type": "dimension",
      "$value": "32px × 1px",
      "$description": "Linha dourada horizontal (#D4AF82) usada como separador entre eyebrow e heading."
    },
    "card-hover-lift": {
      "$type": "dimension",
      "$value": "-5px",
      "$description": "translateY aplicado aos cards em hover."
    }
  }
}
